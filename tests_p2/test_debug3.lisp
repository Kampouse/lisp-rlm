(define (run)
  ;; Debug: Dump RET_AREA and first bytes of stdin buffer
  (let* ((disc (byte-at 126976))  ;; RET_AREA+0 (discriminant low byte)
         (ptr0 (byte-at 126980))   ;; RET_AREA+4 (pointer low byte)
         (ptr1 (byte-at 126981))
         (ptr2 (byte-at 126982))
         (ptr3 (byte-at 126983))
         (len0 (byte-at 126984))   ;; RET_AREA+8 (length low byte)
         (len1 (byte-at 126985))
         (len2 (byte-at 126986))
         (len3 (byte-at 126987))
         (stdin0 (byte-at 32768))  ;; STDIN_BUF first byte
         (stdin1 (byte-at 32769))
         (stdin2 (byte-at 32770))
         (stdin3 (byte-at 32771)))
    (str-cat "{\"disc\":" (to-string disc)
             ",\"ptr\":" (to-string ptr0) "," (to-string ptr1) "," (to-string ptr2) "," (to-string ptr3)
             ",\"len\":" (to-string len0) "," (to-string len1) "," (to-string len2) "," (to-string len3)
             ",\"stdin\":" (to-string stdin0) "," (to-string stdin1) "," (to-string stdin2) "," (to-string stdin3)
             "}")))