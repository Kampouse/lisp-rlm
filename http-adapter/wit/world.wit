package lisp:http-adapter@0.1.0;

interface api {
  http-get: func(url: string) -> result<list<u8>, string>;
  http-post: func(url: string, body: list<u8>, content-type: string) -> result<list<u8>, string>;
}

world adapter {
  import wasi:http/types@0.2.2;
  import wasi:http/outgoing-handler@0.2.2;
  import wasi:io/poll@0.2.2;
  export api;
}
