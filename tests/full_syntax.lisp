;;; Full Syntax Coverage Test — lisp-rlm
;;; Each form has ;; => expected_result
;;; Runner validates the expected result.

;;; ============================================================
;;; SECTION 1: Literals
;;; ============================================================

42                  ;; => 42
-7                  ;; => -7
3.14                ;; => 3.14
"hello"             ;; => "hello"
true                ;; => true
false               ;; => false
nil                 ;; => nil
'foo                ;; => foo
'(1 2 3)            ;; => (1 2 3)
:kw                 ;; => :kw

;;; ============================================================
;;; SECTION 2: Arithmetic
;;; ============================================================

(+ 1 2)             ;; => 3
(- 10 3)            ;; => 7
(* 4 5)             ;; => 20
(/ 10 2)            ;; => 5
(% 7 3)             ;; => 1
(inc 5)             ;; => 6
(dec 5)             ;; => 4
(abs -5)            ;; => 5
(min 3 1 2)         ;; => 1
(max 3 1 2)         ;; => 3
(+ 1.5 2.5)         ;; => 4.0
(sqrt 16)           ;; => 4
(pow 2 10)          ;; => 1024

;;; ============================================================
;;; SECTION 3: Comparison & Logic
;;; ============================================================

(= 1 1)             ;; => true
(= 1 2)             ;; => false
(< 1 2)             ;; => true
(> 2 1)             ;; => true
(<= 1 1)            ;; => true
(>= 2 1)            ;; => true
(not false)         ;; => true
(and true true)     ;; => true
(and true false)    ;; => false
(or false true)     ;; => true
(or false false)    ;; => false
(zero? 0)           ;; => true
(pos? 5)            ;; => true
(neg? -3)           ;; => true
(even? 4)           ;; => true
(odd? 3)            ;; => true

;;; ============================================================
;;; SECTION 4: Conditionals
;;; ============================================================

(if true 1 2)                    ;; => 1
(if false 1 2)                   ;; => 2
(if nil 1 2)                     ;; => 2
(cond (false 1) (true 2) (else 3))  ;; => 2
(cond (true 99))                     ;; => 99
(when true 42)                   ;; => 42
(when false 42)                  ;; => nil
(unless false 42)                ;; => 42
(unless true 42)                 ;; => nil

;;; ============================================================
;;; SECTION 5: Let bindings
;;; ============================================================

(let ((x 10)) x)                          ;; => 10
(let ((x 10) (y 20)) (+ x y))             ;; => 30
(let ((x 1)) (let ((x 2)) x))             ;; => 2
(let ((x (+ 1 2)) (y (* 3 4))) (+ x y))   ;; => 15

;;; named let — simple countdown
(let countdown ((n 3))
  (if (= n 0) 0
    (countdown (- n 1))))                  ;; => 0

;;; named let — accumulating sum
(let loop ((i 1) (acc 0))
  (if (> i 5) acc
    (loop (+ i 1) (+ acc i))))             ;; => 15

;;; ============================================================
;;; SECTION 6: Define
;;; ============================================================

(define x 42)
x                                        ;; => 42

(define (square n) (* n n))
(square 7)                               ;; => 49

(define (fact n)
  (if (= n 0) 1
    (* n (fact (- n 1)))))
(fact 5)                                 ;; => 120

;;; define inside begin
(begin
  (define local-var 99)
  local-var)                             ;; => 99

;;; ============================================================
;;; SECTION 7: Lambda
;;; ============================================================

((lambda (x) (* x x)) 5)                ;; => 25

(define adder (lambda (a b) (+ a b)))
(adder 3 4)                              ;; => 7

;;; lambda with rest params
(define my-list (lambda args args))
(my-list 1 2 3)                          ;; => (1 2 3)

;;; fn alias
((fn (x) (+ x 1)) 10)                   ;; => 11

;;; ============================================================
;;; SECTION 8: Set!
;;; ============================================================

(define counter 0)
(set! counter 10)
counter                                  ;; => 10

;;; ============================================================
;;; SECTION 9: Quote / Quasiquote
;;; ============================================================

(quote hello)                            ;; => hello
'(1 2 3)                                 ;; => (1 2 3)
`(+ 1 2)                                 ;; => (+ 1 2)

(define z 99)
`(before ,z after)                       ;; => (before 99 after)
`(a ,@(list 1 2 3) b)                    ;; => (a 1 2 3 b)

;;; ============================================================
;;; SECTION 10: Begin / Progn
;;; ============================================================

(begin 1 2 3)                            ;; => 3
(progn 10 20 30)                         ;; => 30

;;; ============================================================
;;; SECTION 11: Loop / Recur
;;; ============================================================

;;; basic loop
(loop ((i 0))
  (if (= i 5) i
    (recur (+ i 1))))                    ;; => 5

;;; loop with accumulator — factorial
(loop ((n 6) (acc 1))
  (if (= n 0) acc
    (recur (- n 1) (* acc n))))          ;; => 720

;;; loop building list
(loop ((i 3) (acc ()))
  (if (= i 0) acc
    (recur (- i 1) (cons i acc))))       ;; => (1 2 3)

;;; ============================================================
;;; SECTION 12: Do loop
;;; ============================================================

(do ((i 0 (+ i 1)))
    ((= i 5) i)
  nil)                                   ;; => 5

;;; ============================================================
;;; SECTION 13: Dotimes
;;; ============================================================

(dotimes (i 5) i)                        ;; => 5

;;; ============================================================
;;; SECTION 14: While
;;; ============================================================

(define w 0)
(while (< w 3)
  (set! w (+ w 1)))
w                                        ;; => 3

;;; ============================================================
;;; SECTION 15: Match
;;; ============================================================

(match 42
  (0 "zero")
  (_ "other"))                           ;; => "other"

(match (list 1 2 3)
  ((list 1 _ _) "starts with 1")
  (_ "no"))                              ;; => "starts with 1"

;;; ============================================================
;;; SECTION 16: Try / Catch
;;; ============================================================

(try
  (error "boom")
  (catch e (str "caught: " e)))          ;; => "caught: boom"

(try
  42
  (catch e 0))                           ;; => 42

;;; ============================================================
;;; SECTION 17: List operations
;;; ============================================================

(list 1 2 3)                 ;; => (1 2 3)
(car '(1 2 3))               ;; => 1
(cdr '(1 2 3))               ;; => (2 3)
(cons 0 '(1 2))              ;; => (0 1 2)
(length '(1 2 3))            ;; => 3
(empty? '())                 ;; => true
(empty? '(1))                ;; => false
(append '(1 2) '(3 4))       ;; => (1 2 3 4)
(reverse '(1 2 3))           ;; => (3 2 1)
(first '(10 20 30))          ;; => 10
(rest '(10 20 30))           ;; => (20 30)
(last '(10 20 30))           ;; => 30
(butlast '(10 20 30))        ;; => (10 20)
(nth '(10 20 30) 0)          ;; => 10
(nth '(10 20 30) 2)          ;; => 30
(take 2 '(1 2 3 4))          ;; => (1 2)
(drop 2 '(1 2 3 4))          ;; => (3 4)
(range 5)                    ;; => (0 1 2 3 4)
(range 2 5)                  ;; => (2 3 4)

;;; ============================================================
;;; SECTION 18: Higher-order functions
;;; ============================================================

(map (lambda (x) (* x 2)) '(1 2 3))            ;; => (2 4 6)
(filter (lambda (x) (= (% x 2) 0)) '(1 2 3 4 5 6))  ;; => (2 4 6)
(reduce (lambda (acc x) (+ acc x)) 0 '(1 2 3 4 5))   ;; => 15
(sort '(3 1 2))                                 ;; => (1 2 3)
(apply + '(1 2 3))                              ;; => 6
(for-each (lambda (x) x) '(1 2 3))             ;; => nil

;;; ============================================================
;;; SECTION 19: String operations
;;; ============================================================

(str "hello" " " "world")              ;; => "hello world"
(str-length "hello")                   ;; => 5
(str-concat "foo" "bar")               ;; => "foobar"
(str-split "a,b,c" ",")               ;; => (a b c)
(str-contains "hello" "ell")           ;; => true
(substring "hello" 1 3)                ;; => "el"

;;; ============================================================
;;; SECTION 20: Type predicates
;;; ============================================================

(number? 42)             ;; => true
(string? "hi")           ;; => true
(list? '(1 2))           ;; => true
(symbol? 'foo)           ;; => true
(boolean? true)          ;; => true
(int? 42)                ;; => true
(float? 3.14)            ;; => true
(nil? nil)               ;; => true
(pair? '(1 2))           ;; => true
(equal? 42 42)           ;; => true
(equal? 42 43)           ;; => false

;;; ============================================================
;;; SECTION 21: Dict operations
;;; ============================================================

(define d (dict "a" 1 "b" 2))
(dict-ref d "a")                        ;; => 1
(dict-set d "c" 3)                      ;; => (dict a 1 b 2 c 3)

;;; ============================================================
;;; SECTION 22: Type conversions
;;; ============================================================

(to-string 42)             ;; => "42"
(to-int "42")              ;; => 42
(to-float "3.14")          ;; => 3.14

;;; ============================================================
;;; SECTION 23: Macro definition
;;; ============================================================

(defmacro my-when (test body)
  (list 'if test body nil))
(my-when true 42)                       ;; => 42
(my-when false 42)                      ;; => nil

;;; ============================================================
;;; SECTION 24: Eval
;;; ============================================================

(eval '(+ 1 2))                         ;; => 3

;;; ============================================================
;;; SECTION 25: Error handling
;;; ============================================================

(error "test error")                    ;; => ERROR

;;; ============================================================
;;; SECTION 26: Closure over let
;;; ============================================================

(define make-adder
  (lambda (n)
    (lambda (x) (+ x n))))
(define add5 (make-adder 5))
(add5 10)                               ;; => 15

;;; ============================================================
;;; SECTION 27: Composition
;;; ============================================================

(define (compose f g) (lambda (x) (f (g x))))
(define inc-then-double (compose (lambda (x) (* x 2)) (lambda (x) (+ x 1))))
(inc-then-double 4)                     ;; => 10
